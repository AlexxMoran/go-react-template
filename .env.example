# Root docker-compose overrides. Copy to `.env` (gitignored) to change the host
# ports the stack publishes — useful when another project already uses the
# defaults. Container-internal ports and the compose network are unaffected, so
# only host access (browser, psql, host-side `make migrate-up`) follows these.
#
#   cp .env.example .env   # then edit and `make up`

# Defaults shown. Uncomment and change the ones that collide on your machine.
# DB_HOST_PORT=5433
# REDIS_HOST_PORT=6379
# MAILPIT_UI_PORT=8025
# MAILPIT_SMTP_PORT=1025
# API_HOST_PORT=3000
# FRONTEND_HOST_PORT=4200
