# ── Application ───────────────────────────────────────────────
APP_ENV=development               # development | staging | production
LOG_LEVEL=debug                   # debug | info | warn | error

# ── HTTP server ───────────────────────────────────────────────
HTTP_HOST=0.0.0.0
HTTP_PORT=3000
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_SHUTDOWN_TIMEOUT=15s
HTTP_REQUEST_TIMEOUT=15s           # per-request context deadline
HTTP_MAX_BODY_BYTES=1048576        # max request body size (1 MiB)

# ── Rate limiting (per client IP) ─────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=20                  # sustained requests/second per IP
RATE_LIMIT_BURST=40                # momentary burst above the sustained rate

# ── Metrics (Prometheus text endpoint) ───────────────────────
METRICS_ENABLED=false              # true exposes GET /metrics

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=goapp
DB_SSLMODE=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2

# ── Auth / JWT ────────────────────────────────────────────────
# Generate strong secrets, e.g.:  openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-please-32b-min
JWT_REFRESH_SECRET=change-me-refresh-secret-please-32b-min
JWT_ISSUER=goapp
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h               # 7 days

# Refresh-token cookie
COOKIE_SECURE=false                # true in production (HTTPS)
COOKIE_SAMESITE=lax                # lax | strict | none
COOKIE_DOMAIN=

# ── Redis (asynq job broker) ──────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Background jobs (asynq) ────────────────────────────────────
JOBS_ENABLED=true                  # run the worker server + scheduler
JOBS_CONCURRENCY=10                # max tasks processed in parallel

# ── Email ─────────────────────────────────────────────────────
MAIL_DRIVER=log                    # log (prints) | smtp
MAIL_FROM=no-reply@goapp.local
SMTP_HOST=localhost                # in docker compose this is "mailpit"
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Cache (Redis-backed, read-through) ────────────────────────
CACHE_ENABLED=true
CACHE_TTL=60s

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
